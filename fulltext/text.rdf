  <rdf:Description rdf:about="https://example.org/procopius/p/this-digital-edition-presents-selected-e">
    <rdf:type rdf:resource="http://schema.org/CreativeWork"/>
    <schema1:text xml:lang="en">This digital edition presents selected excerpts from  Procopius’ History of the Wars chosen specifically to document the reign and actions of
        Emperor Justinian I (527-565 CE). The selection emphasises passages that describe Justinian’s political decisions,
        his military campaigns (Mesopotamia, Africa, Italy), and the activities of principal commanders such as
        Belisarius.</schema1:text>
