  <rdf:Description rdf:about="https://example.org/procopius/p/we-have-tried-to-keep-page-breaks---to">
    <rdf:type rdf:resource="http://schema.org/CreativeWork"/>
    <schema1:text xml:lang="en">We have tried to keep page breaks (
