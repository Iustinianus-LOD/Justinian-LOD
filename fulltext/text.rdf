  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/procopius/keywords/battle-phalanx-massagetae-immortals">
    <rdf:type rdf:resource="http://schema.org/CreativeWork"/>
    <skos:note>scheme=https://www.wikidata.org/</skos:note>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/term/battle"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/term/phalanx"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/term/massagetae"/>
