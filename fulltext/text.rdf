  <rdf:Description rdf:about="https://example.org/procopius/div/procopius-with-an-english-translation-by">
    <rdf:type rdf:resource="http://schema.org/CreativeWork"/>
    <schema1:text xml:lang="en">PROCOPIUS
        With an English translation by H. B. Dewing
        In seven volumes. Volume I — History of the Wars, Books I and II
        Cambridge, Massachusetts: Harvard University Press
        London: William Heinemann Ltd.
        Imprint on provided image: MCMLXI (1961)</schema1:text>
    <skos:note>type=title_page</skos:note>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/head/procopius"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/p/with-an-english-translation-by-h.-b.-dew"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/p/in-seven-volumes.-volume-i--history-of"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/p/cambridge-massachusetts-harvard-univer"/>
