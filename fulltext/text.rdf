  <rdf:Description rdf:about="https://example.org/procopius/titleStmt/procopius-history-of-the-wars-books-i-a">
    <rdf:type rdf:resource="http://schema.org/CreativeWork"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/title/procopius"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/title/history-of-the-wars-books-i-and-ii"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/author/procopius-of-caesarea"/>
    <dcterms:hasPart rdf:resource="https://example.org/procopius/respStmt/digital-encoding-by-maria-concetta-de-ma"/>
